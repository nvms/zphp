#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
ZPHP="$ROOT_DIR/zig-out/bin/zphp"

# build zphp if needed
if [ ! -f "$ZPHP" ]; then
    echo "building zphp..."
    cd "$ROOT_DIR" && zig build
fi

# colors
G='\033[32m'
Y='\033[33m'
C='\033[36m'
R='\033[0m'

cleanup() {
    echo ""
    echo "cleaning up..."
    kill $ZPHP_HTTP_PID $ZPHP_WS_PID 2>/dev/null || true
    cd "$SCRIPT_DIR" && docker compose down 2>/dev/null || true
    wait 2>/dev/null
}
trap cleanup EXIT

# -------------------------------------------------------------------
# HTTP benchmark
# -------------------------------------------------------------------

echo -e "${C}=== HTTP benchmark ===${R}"
echo ""

# start php-fpm
echo -e "${Y}starting php-fpm (nginx + php-fpm, 128 workers)...${R}"
cd "$SCRIPT_DIR" && docker compose up -d php-fpm 2>/dev/null
sleep 3

# start zphp
echo -e "${Y}starting zphp serve...${R}"
$ZPHP serve "$SCRIPT_DIR/app.php" --port 8083 &
ZPHP_HTTP_PID=$!
sleep 1

# start swoole
echo -e "${Y}starting swoole (4 workers)...${R}"
cd "$SCRIPT_DIR" && docker compose up -d swoole 2>/dev/null
sleep 3

# verify all are running
echo -e "${Y}verifying servers...${R}"
curl -s http://localhost:8081/ > /dev/null && echo "  php-fpm: ok" || echo "  php-fpm: FAILED"
curl -s http://localhost:8082/ > /dev/null && echo "  swoole: ok" || echo "  swoole: FAILED"
curl -s http://localhost:8083/ > /dev/null && echo "  zphp: ok" || echo "  zphp: FAILED"
echo ""

# HTTP throughput test using python
echo -e "${C}--- HTTP throughput (1000 requests, 50 concurrent) ---${R}"
python3 "$SCRIPT_DIR/http_bench.py"

# stop HTTP servers
kill $ZPHP_HTTP_PID 2>/dev/null || true
wait $ZPHP_HTTP_PID 2>/dev/null || true
cd "$SCRIPT_DIR" && docker compose down 2>/dev/null

echo ""

# -------------------------------------------------------------------
# WebSocket benchmark
# -------------------------------------------------------------------

echo -e "${C}=== WebSocket benchmark ===${R}"
echo ""

# start swoole ws
echo -e "${Y}starting swoole websocket...${R}"
cd "$SCRIPT_DIR"
docker compose run -d --name swoole_ws -p 8082:9501 swoole php /app/ws_server.php 2>/dev/null
sleep 3

# start zphp ws
echo -e "${Y}starting zphp websocket...${R}"
$ZPHP serve "$SCRIPT_DIR/zphp_ws.php" --port 8083 &
ZPHP_WS_PID=$!
sleep 1

echo -e "${C}--- WebSocket concurrent connections + memory ---${R}"
python3 "$SCRIPT_DIR/ws_bench.py"

# cleanup handled by trap
