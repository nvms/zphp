#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ZPHP="${ZPHP:-$SCRIPT_DIR/../zig-out/bin/zphp}"

passed=0
failed=0
errors=""

check() {
    local name="$1"
    local expected="$2"
    local actual="$3"
    if [ "$expected" = "$actual" ]; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected: $expected\ngot: $actual\n"
    fi
}

check_exists() {
    local name="$1"
    local path="$2"
    if [ -e "$path" ]; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected $path to exist\n"
    fi
}

check_contains() {
    local name="$1"
    local needle="$2"
    local haystack="$3"
    if printf '%s\n' "$haystack" | grep -qF "$needle"; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected to contain: $needle\ngot: $haystack\n"
    fi
}

# work in a temp directory
WORKDIR=$(mktemp -d)
trap "rm -rf $WORKDIR" EXIT
cd "$WORKDIR"

# test: install from composer.json
cat > composer.json << 'EOF'
{
    "require": {
        "psr/log": "^3.0"
    }
}
EOF

"$ZPHP" install 2>/dev/null
check_exists "vendor dir created" "vendor"
check_exists "autoload.php created" "vendor/autoload.php"
check_exists "zphp.lock created" "zphp.lock"
check_exists "package downloaded" "vendor/psr/log"
check_exists "psr/log src exists" "vendor/psr/log/src/LoggerInterface.php"

# test: lock file content
lock_content=$(cat zphp.lock)
check_contains "lock has package name" '"psr/log"' "$lock_content"
check_contains "lock has version" '"version"' "$lock_content"

# test: autoloader content
autoload_content=$(cat vendor/autoload.php)
check_contains "autoloader has psr4 map" "Psr\\\\Log\\\\" "$autoload_content"
check_contains "autoloader has spl_autoload" "spl_autoload_register" "$autoload_content"

# test: constraint matching resolves correct major version
lock_content=$(cat zphp.lock)
check_contains "constraint picked 3.x" '"3.' "$lock_content"

# test: packages command
pkg_output=$("$ZPHP" packages 2>&1)
check_contains "packages lists psr/log" "psr/log" "$pkg_output"

# clean up for transitive deps test
rm -rf vendor zphp.lock composer.json

# test: transitive dependency resolution via install
cat > composer.json << 'EOF'
{
    "require": {
        "monolog/monolog": "^3.0"
    }
}
EOF

"$ZPHP" install 2>/dev/null
check_exists "monolog downloaded" "vendor/monolog/monolog"
check_exists "transitive psr/log downloaded" "vendor/psr/log"

# lock file should contain both packages
lock_content=$(cat zphp.lock)
check_contains "lock has monolog" '"monolog/monolog"' "$lock_content"
check_contains "lock has transitive psr/log" '"psr/log"' "$lock_content"

# autoloader should have entries for both
autoload_content=$(cat vendor/autoload.php)
check_contains "autoloader has monolog" "Monolog" "$autoload_content"
check_contains "autoloader has psr/log" "Psr\\\\Log\\\\" "$autoload_content"

# packages command should list both
pkg_output=$("$ZPHP" packages 2>&1)
check_contains "packages lists monolog" "monolog/monolog" "$pkg_output"
check_contains "packages lists transitive dep" "psr/log" "$pkg_output"

# clean up for add test
rm -rf vendor zphp.lock composer.json

# test: add with transitive deps
"$ZPHP" add monolog/monolog 2>/dev/null
check_exists "add: monolog downloaded" "vendor/monolog/monolog"
check_exists "add: transitive psr/log downloaded" "vendor/psr/log"
lock_content=$(cat zphp.lock)
check_contains "add: lock has monolog" '"monolog/monolog"' "$lock_content"
check_contains "add: lock has transitive psr/log" '"psr/log"' "$lock_content"
check_exists "add: composer.json created" "composer.json"

# test: remove leaves lock file consistent
"$ZPHP" remove monolog/monolog 2>/dev/null
lock_content=$(cat zphp.lock)
check_contains "remove: psr/log still in lock" '"psr/log"' "$lock_content"

# test: install skips ext-* constraints
rm -rf vendor zphp.lock composer.json
cat > composer.json << 'EOF'
{
    "require": {
        "psr/log": "^3.0",
        "ext-mbstring": "*"
    }
}
EOF
install_output=$("$ZPHP" install 2>&1)
check_exists "ext skip: psr/log downloaded" "vendor/psr/log"

echo ""
echo "$passed passed, $failed failed"

if [ $failed -gt 0 ]; then
    echo -e "$errors"
    exit 1
fi
