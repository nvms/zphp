#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ZPHP="${ZPHP:-$SCRIPT_DIR/../zig-out/bin/zphp}"
PORT=19876
APP="$SCRIPT_DIR/serve/app.php"

if [ ! -f "$ZPHP" ]; then
    echo "zphp not found at $ZPHP"
    exit 1
fi

passed=0
failed=0
errors=""

# start server
"$ZPHP" serve "$APP" --port $PORT --workers 2 &
SERVER_PID=$!
cleanup() { kill $SERVER_PID 2>/dev/null || true; wait $SERVER_PID 2>/dev/null || true; exit "${EXIT_CODE:-0}"; }
trap cleanup EXIT

# wait for server to start
for i in $(seq 1 20); do
    if curl -s -o /dev/null "http://localhost:$PORT/health" 2>/dev/null; then
        break
    fi
    sleep 0.1
done

check() {
    local name="$1"
    local expected="$2"
    local actual="$3"

    if [ "$expected" = "$actual" ]; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected: $expected\ngot: $actual\n"
    fi
}

check_contains() {
    local name="$1"
    local needle="$2"
    local haystack="$3"

    if echo "$haystack" | grep -q "$needle"; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected to contain: $needle\ngot: $haystack\n"
    fi
}

# test: health endpoint returns 200 with json
resp=$(curl -s http://localhost:$PORT/health)
check "health body" '{"status":"ok"}' "$resp"

# test: GET params
resp=$(curl -s "http://localhost:$PORT/echo?name=alice&age=30")
check_contains "get params name" '"name":"alice"' "$resp"
check_contains "get params age" '"age":"30"' "$resp"
check_contains "get method" '"method":"GET"' "$resp"

# test: POST form data
resp=$(curl -s -X POST -H "Content-Type: application/x-www-form-urlencoded" -d "key=val" "http://localhost:$PORT/echo")
check_contains "post data" '"key":"val"' "$resp"
check_contains "post method" '"method":"POST"' "$resp"

# test: custom headers
headers=$(curl -si http://localhost:$PORT/headers 2>&1)
check_contains "custom header X-Custom" "X-Custom: hello" "$headers"
check_contains "custom header X-Another" "X-Another: world" "$headers"

# test: header replace (default behavior - last value wins)
replace_hdrs=$(curl -si http://localhost:$PORT/header-replace 2>&1)
check_contains "header replace last wins" "X-Test: second" "$replace_hdrs"

# test: header no-replace (append)
noreplace_hdrs=$(curl -si http://localhost:$PORT/header-no-replace 2>&1)
check_contains "header no-replace first" "X-Multi: one" "$noreplace_hdrs"
check_contains "header no-replace second" "X-Multi: two" "$noreplace_hdrs"

# test: header_remove specific
remove_hdrs=$(curl -si http://localhost:$PORT/header-remove 2>&1)
check_contains "header_remove keeps X-Keep" "X-Keep: yes" "$remove_hdrs"
if echo "$remove_hdrs" | grep -q "X-Drop:"; then
    failed=$((failed + 1))
    echo "  FAIL  header_remove drops X-Drop"
    errors="$errors\n--- header_remove drops X-Drop ---\nexpected X-Drop to be absent\ngot: $remove_hdrs\n"
else
    passed=$((passed + 1))
    echo "  pass  header_remove drops X-Drop"
fi

# test: header_remove all
removeall_hdrs=$(curl -si http://localhost:$PORT/header-remove-all 2>&1)
if echo "$removeall_hdrs" | grep -q "X-A:\|X-B:"; then
    failed=$((failed + 1))
    echo "  FAIL  header_remove all"
    errors="$errors\n--- header_remove all ---\nexpected no X-A/X-B headers\ngot: $removeall_hdrs\n"
else
    passed=$((passed + 1))
    echo "  pass  header_remove all"
fi

# test: headers_list
list_body=$(curl -s http://localhost:$PORT/header-list 2>&1)
check_contains "headers_list contains X-Foo" "X-Foo: bar" "$list_body"
check_contains "headers_list contains X-Baz" "X-Baz: qux" "$list_body"

# test: header with status code arg
hdr_status=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$PORT/header-status)
check "header status code arg" "202" "$hdr_status"

# test: header() from inside a function (frames[0] fix)
func_hdrs=$(curl -si http://localhost:$PORT/header-from-function 2>&1)
check_contains "header from function" "X-From-Func: yes" "$func_hdrs"
func_status=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$PORT/header-from-function)
check "response code from function" "203" "$func_status"

# test: status code
status=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$PORT/status)
check "status 201" "201" "$status"

# test: 404
status=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$PORT/nonexistent)
check "status 404" "404" "$status"

# test: content-type html
ct=$(curl -si http://localhost:$PORT/html 2>&1 | grep -i "Content-Type" | tr -d '\r')
check_contains "html content-type" "text/html" "$ct"

# test: request uri includes query string
resp=$(curl -s "http://localhost:$PORT/echo?x=1")
check_contains "request uri has query" '"/echo?x=1"' "$resp"

# test: keep-alive (multiple requests on same connection)
ka_resp=$(curl -s http://localhost:$PORT/health http://localhost:$PORT/health 2>&1)
ka_count=$(echo "$ka_resp" | grep -o '"status":"ok"' | wc -l | tr -d ' ')
check "keep-alive two responses" "2" "$ka_count"

# test: connection header
ka_headers=$(curl -si http://localhost:$PORT/health -H "Connection: keep-alive" 2>&1)
check_contains "keep-alive header" "keep-alive" "$ka_headers"

# test: static CSS file
css_resp=$(curl -si http://localhost:$PORT/style.css 2>&1)
check_contains "css body" "font-family" "$css_resp"
check_contains "css content-type" "text/css" "$css_resp"

# test: static JS file
js_ct=$(curl -si http://localhost:$PORT/script.js 2>&1 | grep -i "Content-Type" | tr -d '\r')
check_contains "js content-type" "javascript" "$js_ct"

# test: static JSON file
json_resp=$(curl -s http://localhost:$PORT/data.json)
check_contains "json body" '"key"' "$json_resp"

# test: static HTML file
html_resp=$(curl -si http://localhost:$PORT/index.html 2>&1)
check_contains "html static body" "<h1>Hello</h1>" "$html_resp"
check_contains "html static content-type" "text/html" "$html_resp"

# test: ETag and 304 Not Modified
etag=$(curl -si http://localhost:$PORT/style.css 2>&1 | grep -i "ETag" | tr -d '\r' | awk '{print $2}')
if [ -n "$etag" ]; then
    status304=$(curl -s -o /dev/null -w "%{http_code}" -H "If-None-Match: $etag" http://localhost:$PORT/style.css)
    check "304 not modified" "304" "$status304"
else
    echo "  FAIL  etag missing"
    failed=$((failed + 1))
fi

# test: Cache-Control header on static files
cache_hdr=$(curl -si http://localhost:$PORT/style.css 2>&1 | grep -i "Cache-Control" | tr -d '\r')
check_contains "cache-control header" "max-age" "$cache_hdr"

# test: directory traversal blocked
traversal_status=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$PORT/../../../etc/passwd")
check "traversal blocked" "404" "$traversal_status"

# test: PHP still works alongside static files
php_resp=$(curl -s http://localhost:$PORT/health)
check "php still works" '{"status":"ok"}' "$php_resp"

# test: state isolation (no leaks between requests)
r1=$(curl -s "http://localhost:$PORT/echo?seq=1")
r2=$(curl -s "http://localhost:$PORT/echo?seq=2")
check_contains "isolation req1" '"seq":"1"' "$r1"
check_contains "isolation req2" '"seq":"2"' "$r2"

# test: chunked transfer encoding (raw HTTP over TCP)
chunked_resp=$(python3 -c "
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.connect(('localhost', $PORT))
s.sendall(b'POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nContent-Type: application/x-www-form-urlencoded\r\nConnection: close\r\n\r\n7\r\nkey=val\r\n0\r\n\r\n')
data = b''
while True:
    chunk = s.recv(4096)
    if not chunk: break
    data += chunk
s.close()
print(data.decode())
" 2>&1)
check_contains "chunked post data" '"key":"val"' "$chunked_resp"

# test: multipart form data
upload_resp=$(curl -s -F "field1=hello" -F "field2=world" "http://localhost:$PORT/upload")
check_contains "multipart field1" '"field1":"hello"' "$upload_resp"
check_contains "multipart field2" '"field2":"world"' "$upload_resp"

# test: file upload via multipart
echo "test file content" > /tmp/zphp_test_upload.txt
file_resp=$(curl -s -F "myfile=@/tmp/zphp_test_upload.txt" "http://localhost:$PORT/upload")
check_contains "file upload name" '"name":"zphp_test_upload.txt"' "$file_resp"
check_contains "file upload has_tmp" '"has_tmp":true' "$file_resp"
check_contains "file upload error" '"error":0' "$file_resp"
rm -f /tmp/zphp_test_upload.txt

# test: php://input with JSON body
json_resp=$(curl -s -X POST -H "Content-Type: application/json" -d '{"name":"alice","age":30}' "http://localhost:$PORT/json-api")
check_contains "php://input raw length" '"raw_length":25' "$json_resp"
check_contains "php://input parsed name" '"name":"alice"' "$json_resp"
check_contains "php://input parsed age" '"age":30' "$json_resp"

# test: sessions - set value and get cookie
session_resp=$(curl -si "http://localhost:$PORT/session-set?user=alice" 2>&1)
session_cookie=$(echo "$session_resp" | grep -i "Set-Cookie: PHPSESSID=" | sed 's/.*PHPSESSID=//;s/;.*//' | tr -d '\r')
check_contains "session set user" '"user":"alice"' "$session_resp"
check_contains "session set count" '"count":1' "$session_resp"

if [ -n "$session_cookie" ]; then
    # test: session persistence across requests
    get_resp=$(curl -s -b "PHPSESSID=$session_cookie" "http://localhost:$PORT/session-get")
    check_contains "session persist user" '"user":"alice"' "$get_resp"

    # test: session counter increments
    inc_resp=$(curl -s -b "PHPSESSID=$session_cookie" "http://localhost:$PORT/session-set?user=alice")
    check_contains "session count increment" '"count":2' "$inc_resp"

    # test: session destroy
    destroy_resp=$(curl -s -b "PHPSESSID=$session_cookie" "http://localhost:$PORT/session-destroy")
    check_contains "session destroy" '"destroyed":true' "$destroy_resp"

    # test: after destroy, session data is gone
    after_resp=$(curl -s -b "PHPSESSID=$session_cookie" "http://localhost:$PORT/session-get")
    check_contains "session after destroy" '"count":0' "$after_resp"

    # cleanup session files
    rm -f /tmp/sess_${session_cookie}
else
    echo "  FAIL  session cookie not set"
    failed=$((failed + 5))
fi

# --- TLS tests ---
TLS_PORT=19877
openssl req -x509 -newkey rsa:2048 -keyout /tmp/zphp_test.key -out /tmp/zphp_test.crt -days 1 -nodes -subj "/CN=localhost" 2>/dev/null

"$ZPHP" serve "$APP" --port $TLS_PORT --workers 2 --tls-cert /tmp/zphp_test.crt --tls-key /tmp/zphp_test.key &
TLS_PID=$!

for i in $(seq 1 20); do
    if curl -sk -o /dev/null "https://localhost:$TLS_PORT/health" 2>/dev/null; then
        break
    fi
    sleep 0.1
done

tls_health=$(curl -sk https://localhost:$TLS_PORT/health)
check "tls health" '{"status":"ok"}' "$tls_health"

tls_get=$(curl -sk "https://localhost:$TLS_PORT/echo?name=bob")
check_contains "tls get params" '"name":"bob"' "$tls_get"

tls_post=$(curl -sk -X POST -H "Content-Type: application/x-www-form-urlencoded" -d "key=val" "https://localhost:$TLS_PORT/echo")
check_contains "tls post data" '"key":"val"' "$tls_post"

tls_status=$(curl -sk -o /dev/null -w "%{http_code}" https://localhost:$TLS_PORT/status)
check "tls status 201" "201" "$tls_status"

kill $TLS_PID 2>/dev/null; wait $TLS_PID 2>/dev/null || true

# --- HTTP/2 tests ---
H2_PORT=19880

"$ZPHP" serve "$APP" --port $H2_PORT --workers 2 --tls-cert /tmp/zphp_test.crt --tls-key /tmp/zphp_test.key &
H2_PID=$!
for i in $(seq 1 20); do
    if curl -sk -o /dev/null "https://localhost:$H2_PORT/health" 2>/dev/null; then break; fi
    sleep 0.1
done

h2_proto=$(curl -sk -o /dev/null -w "%{http_version}" --http2 https://localhost:$H2_PORT/health)
check "h2 negotiation" "2" "$h2_proto"

h2_health=$(curl -sk --http2 https://localhost:$H2_PORT/health)
check "h2 health" '{"status":"ok"}' "$h2_health"

h2_get=$(curl -sk --http2 "https://localhost:$H2_PORT/echo?name=alice&age=30")
check_contains "h2 get params name" '"name":"alice"' "$h2_get"

h2_post=$(curl -sk --http2 -X POST -H "Content-Type: application/x-www-form-urlencoded" -d "key=val" "https://localhost:$H2_PORT/echo")
check_contains "h2 post data" '"key":"val"' "$h2_post"

h2_status=$(curl -sk --http2 -o /dev/null -w "%{http_code}" https://localhost:$H2_PORT/status)
check "h2 status 201" "201" "$h2_status"

h1_fallback=$(curl -sk --http1.1 https://localhost:$H2_PORT/health)
check "h1 fallback" '{"status":"ok"}' "$h1_fallback"

h2_multi=$(curl -sk --http2 https://localhost:$H2_PORT/health https://localhost:$H2_PORT/health https://localhost:$H2_PORT/health 2>&1)
h2_count=$(echo "$h2_multi" | grep -o '"status":"ok"' | wc -l | tr -d ' ')
check "h2 multiplexing" "3" "$h2_count"

kill $H2_PID 2>/dev/null; wait $H2_PID 2>/dev/null || true

# --- WebSocket tests (WS + WSS) ---
WS_PORT=19878
WSS_PORT=19879
WS_APP="$SCRIPT_DIR/serve/ws_app.php"

"$ZPHP" serve "$WS_APP" --port $WS_PORT --workers 1 &
WS_PID=$!

"$ZPHP" serve "$WS_APP" --port $WSS_PORT --workers 1 --tls-cert /tmp/zphp_test.crt --tls-key /tmp/zphp_test.key &
WSS_PID=$!

sleep 1

ws_result=$(python3 -c "
import socket, os, base64, struct

def ws_connect(host, port, use_tls=False):
    import ssl as ssl_mod
    key = base64.b64encode(os.urandom(16)).decode()
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    if use_tls:
        ctx = ssl_mod.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl_mod.CERT_NONE
        s = ctx.wrap_socket(s, server_hostname='localhost')
    s.connect((host, port))
    s.settimeout(5)
    req = 'GET / HTTP/1.1\r\nHost: localhost\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Key: ' + key + '\r\nSec-WebSocket-Version: 13\r\n\r\n'
    s.sendall(req.encode())
    resp = b''
    while b'\r\n\r\n' not in resp:
        resp += s.recv(4096)
    if b'101' not in resp:
        return None
    return s

def read_frame(sock):
    hdr = b''
    while len(hdr) < 2:
        hdr += sock.recv(2 - len(hdr))
    length = hdr[1] & 0x7f
    if length == 126:
        ext = b''
        while len(ext) < 2:
            ext += sock.recv(2 - len(ext))
        length = struct.unpack('>H', ext)[0]
    payload = b''
    while len(payload) < length:
        payload += sock.recv(length - len(payload))
    return payload.decode()

def send_frame(sock, msg):
    payload = msg.encode()
    mask_key = os.urandom(4)
    masked = bytes(b ^ mask_key[i % 4] for i, b in enumerate(payload))
    frame = bytes([0x81, 0x80 | len(payload)]) + mask_key + masked
    sock.sendall(frame)

results = []

# WS tests
try:
    s = ws_connect('localhost', $WS_PORT)
    welcome = read_frame(s)
    results.append('ws_welcome=' + welcome)
    send_frame(s, 'ping')
    reply = read_frame(s)
    results.append('ws_ping=' + reply)
    send_frame(s, 'hello')
    reply = read_frame(s)
    results.append('ws_hello=' + reply)
    s.close()
except Exception as e:
    results.append('ws_error=' + str(e))

# WSS tests
try:
    s = ws_connect('localhost', $WSS_PORT, use_tls=True)
    welcome = read_frame(s)
    results.append('wss_welcome=' + welcome)
    send_frame(s, 'ping')
    reply = read_frame(s)
    results.append('wss_ping=' + reply)
    send_frame(s, 'hello')
    reply = read_frame(s)
    results.append('wss_hello=' + reply)
    s.close()
except Exception as e:
    results.append('wss_error=' + str(e))

print('|'.join(results))
" 2>&1)

for pair in $(echo "$ws_result" | tr '|' ' '); do
    key="${pair%%=*}"
    val="${pair#*=}"
    case "$key" in
        ws_welcome) check "ws welcome" "welcome" "$val" ;;
        ws_ping)    check "ws ping/pong" "pong" "$val" ;;
        ws_hello)   check "ws message" "got:hello" "$val" ;;
        wss_welcome) check "wss welcome" "welcome" "$val" ;;
        wss_ping)    check "wss ping/pong" "pong" "$val" ;;
        wss_hello)   check "wss message" "got:hello" "$val" ;;
        ws_error)   failed=$((failed + 3)); echo "  FAIL  ws: $val" ;;
        wss_error)  failed=$((failed + 3)); echo "  FAIL  wss: $val" ;;
    esac
done

kill $WS_PID 2>/dev/null; wait $WS_PID 2>/dev/null || true
kill $WSS_PID 2>/dev/null; wait $WSS_PID 2>/dev/null || true
rm -f /tmp/zphp_test.key /tmp/zphp_test.crt

# test: graceful shutdown
kill -TERM $SERVER_PID
wait $SERVER_PID 2>/dev/null
exit_code=$?
# override cleanup since server is already dead
trap - EXIT
if [ $exit_code -eq 0 ] || [ $exit_code -eq 143 ]; then
    passed=$((passed + 1))
    echo "  pass  graceful shutdown"
else
    failed=$((failed + 1))
    echo "  FAIL  graceful shutdown (exit code: $exit_code)"
    errors="$errors\n--- graceful shutdown ---\nexpected exit 0 or 143, got: $exit_code\n"
fi

echo ""
echo "$passed passed, $failed failed"

if [ $failed -gt 0 ]; then
    echo -e "$errors"
    EXIT_CODE=1
    exit 1
fi
EXIT_CODE=0
