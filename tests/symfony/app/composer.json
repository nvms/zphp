{
    "name": "zphp/symfony-harness",
    "description": "minimal Symfony component harness for exercising zphp's XML, intl, and string extensions against real framework code",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/intl": "^7.0",
        "symfony/string": "^7.0",
        "symfony/dom-crawler": "^7.0",
        "symfony/css-selector": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/property-access": "^7.0",
        "symfony/translation": "^7.0"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
