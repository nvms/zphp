#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ZPHP="${ZPHP:-$SCRIPT_DIR/../zig-out/bin/zphp}"

if ! command -v php &>/dev/null; then
    echo "php not found in PATH"
    exit 1
fi

if [ ! -f "$ZPHP" ]; then
    echo "zphp not found at $ZPHP (build with: zig build)"
    exit 1
fi

passed=0
failed=0
errors=""

for f in "$SCRIPT_DIR"/*.php; do
    name="$(basename "$f")"
    php_out="$(php "$f" 2>&1)" || true
    zphp_out="$("$ZPHP" run "$f" 2>&1)" || true

    if [ "$php_out" = "$zphp_out" ]; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        echo "  FAIL  $name"
        errors="$errors\n--- $name ---\nexpected (php):\n$php_out\ngot (zphp):\n$zphp_out\n"
    fi
done

echo ""
echo "$passed passed, $failed failed"

if [ $failed -gt 0 ]; then
    echo -e "$errors"
    exit 1
fi
