#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ZPHP="${ZPHP:-$SCRIPT_DIR/../../zig-out/bin/zphp}"
APP_DIR="$SCRIPT_DIR/app"

if ! command -v php &>/dev/null; then
    echo "php not found in PATH"
    exit 1
fi

if [ ! -f "$ZPHP" ]; then
    echo "zphp not found at $ZPHP (build with: make build)"
    exit 1
fi

if [ ! -d "$APP_DIR/vendor" ]; then
    echo "run 'tests/laravel/setup' first"
    exit 1
fi

# ensure sqlite database exists
touch "$APP_DIR/database/database.sqlite"
mkdir -p "$APP_DIR/storage/framework/views"

passed=0
failed=0
errors=""

for f in "$SCRIPT_DIR"/harness/test-*.php; do
    name="$(basename "$f" .php)"
    php_out="$(php -d error_reporting=E_ALL\&~E_DEPRECATED\&~E_WARNING "$f" 2>&1)" || true
    zphp_out="$(timeout 30 "$ZPHP" run "$f" 2>&1)"
    zphp_exit=$?

    if [ "$php_out" = "$zphp_out" ]; then
        passed=$((passed + 1))
        echo "  pass  $name"
    else
        failed=$((failed + 1))
        if [ $zphp_exit -eq 124 ]; then
            echo "  FAIL  $name (timeout)"
        elif [ $zphp_exit -ne 0 ]; then
            echo "  FAIL  $name (exit $zphp_exit)"
        else
            echo "  FAIL  $name"
        fi
        errors="$errors\n--- $name ---\nexpected (php):\n$php_out\ngot (zphp):\n$zphp_out\n"
    fi
done

echo ""
echo "$passed passed, $failed failed"

if [ $failed -gt 0 ]; then
    echo -e "$errors"
    exit 1
fi
